<?xml version="1.0" encoding="utf-8"?>
<component name="SettingsMenuItem" extends="Group">
    <children>
        <Poster id="buttonBackground" uri="pkg:/images/hd_focus_filled.9.png" width="747" height="120" />
        <Poster id="focusOutline" uri="pkg:/images/hd_focus.9.png" width="747" height="120" visible="false" />

        <Poster
            id="iconBackground"
            uri="pkg:/images/hd_focus_filled.9.png"
            width="80"
            height="80"
            blendColor="0x142d34"
            translation="[20, 20]"
        />

        <Poster
            id="icon"
            uri="pkg:/images/icons/settings.png"
            width="40"
            height="40"
            translation="[40, 40]"
        />

        <ScrollingText
            id="settingTitle"
            translation="[118, 30]"
            height="24"
            font="font:SmallestBoldSystemFont"
            horizAlign="left"
            maxWidth="480"
            repeatCount="0" />

        <ScrollingText
            id="settingCurrentValue"
            translation="[612, 50]"
            height="24"
            font="font:TinyBoldSystemFont"
            horizAlign="right"
            maxWidth="110"
            repeatCount="0" />

        <ScrollingText
            id="settingDescription"
            translation="[118, 65]"
            height="32"
            font="font:TinySystemFont"
            horizAlign="left"
            maxWidth="480"
            repeatCount="0" />

        <Poster
            id="boolToggle"
            width="80"
            height="80"
            translation="[640, 20]"
            visible="False"
        />
    </children>
    <interface>
        <field id="itemContent" type="node" onChange="itemContentChanged" />
        <field id="itemHasFocus" type="boolean" onChange="focusChanged" />
        <field id="drawFocusFeedback" type="boolean" value="true" />
    </interface>
</component>