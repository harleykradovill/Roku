<?xml version="1.0" encoding="utf-8"?>
<component name="JFServer" extends="Group">

  <interface>
    <field id="itemContent" type="node" onchange="itemContentChanged" />
    <field id="itemHasFocus" type="boolean" onchange="onItemHasFocusChange" />
  </interface>

  <children>
    <Rectangle id="background" translation="[0,0]" width="1120" height="100" />

    <Poster
      id="focusFeedback"
      visible="false"
      translation="[0,0]"
      width="1120"
      height="100"
      uri="pkg:/images/hd_focus.9.png" />

    <Poster id="poster" translation="[28,28]" width="40" height="40" blendColor="#CCCCCCCC" />
    <Group id="labels" translation="[100,15]">
      <Label id="name" horizAlign="left" font="font:SmallestBoldSystemFont" height="65" translation="[0,5]" />
      <Label id="baseUrl" horizAlign="left" font="font:SmallestSystemFont" height="65" translation="[0,40]" color="#CCCCCCCC" />
    </Group>

    <Rectangle id="trashContainer" translation="[500,0]" width="60" height="60">
      <Poster id="trash" width="25" height="25" uri="pkg:/images/icons/trash.png" translation="[18,18]" />
    </Rectangle>
  </children>

</component>