<?xml version="1.0" encoding="utf-8"?>
<component name="SigninScene" extends="JFScreen">
  <children>
    <!-- Background -->
    <Poster
      id="background"
      uri="pkg:/images/bg_login_gradient.png"
      width="1920"
      height="1080"
      translation="[0, 0]" />

    <Rectangle translation="[710, 70]" width="500" height="113" color="0x00000000">
      <Poster
        id="logo"
        uri="pkg:/images/logo.png"
        width="500"
        height="113" />
    </Rectangle>

    <Poster
      id="signInGroup"
      translation="[360, 215]"
      width="1200"
      height="600"
      uri="pkg:/images/surface.9.png">

      <Rectangle id="errorContainer" visible="false" width="600" height="60" translation="[305, 135]">
        <Text id="errorMessage" text="" wrap="true" width="600" font="font:MediumSystemFont" horizAlign="center" color="0xFF6B6BFF" translation="[10, 15]" />
      </Rectangle>

      <Label
        text="Sign In"
        horizAlign="center"
        width="1200"
        height="35"
        font="font:MediumBoldSystemFont"
        color="0xFFFFFFFF"
        translation="[0, 60]" />

      <Label id="connectingTo"
        text="Connecting to -----"
        horizAlign="center"
        width="1200"
        height="35"
        font="font:TinySystemFont"
        color="0x9CA3AFFF"
        translation="[0, 100]" />

      <StandardButton
        id="quickConnect"
        text="Quick Connect"
        height="50"
        width="545"
        translation="[40, 140]"
        background="0x2a2e40FF"
        color="0xFFFFFFFF"
        focusBackground="0x00A4DCFF"
        focusColor="0xFFFFFFFF"
        fontSize="24" />

      <StandardButton
        id="passwordTab"
        text="Password"
        height="50"
        width="545"
        translation="[610, 140]"
        background="0x2a2e40FF"
        color="0xFFFFFFFF"
        focusBackground="0x00A4DCFF"
        focusColor="0xFFFFFFFF"
        fontSize="24" />

      <Rectangle id="signInFormContainer" color="#ffffff00" width="1120" height="280" translation="[40, 170]">
        <Rectangle color="0x2a2e40FF" width="1110" height="75" translation="[5, 40]" />
        <Rectangle color="0x2a2e40FF" width="1110" height="75" translation="[5, 165]" />

        <FormList id="configOptions" translation="[36, 40]" itemSpacing="[0, 50]" />

        <CheckList
          id="saveCredentials"
          checkedState="[true]"
          translation="[5, 245]"
          focusFootprintBitmapUri=""
          drawFocusFeedback="false">
          <ContentNode role="content">
            <ContentNode title="Save Credentials?" />
          </ContentNode>
        </CheckList>

        <StandardButton
          id="submit"
          text="Sign In"
          height="50"
          width="545"
          translation="[570, 345]"
          background="0x2a2e40FF"
          color="0xFFFFFFFF"
          focusBackground="0x00A4DCFF"
          focusColor="0xFFFFFFFF"
          fontSize="24" />

        <StandardButton
          id="back"
          text="Back"
          height="50"
          width="545"
          translation="[0, 345]"
          background="0x2a2e40FF"
          color="0xFFFFFFFF"
          focusBackground="0x00A4DCFF"
          focusColor="0xFFFFFFFF"
          fontSize="24" />
      </Rectangle>

      <Group id="quickConnectGroup" visible="false" translation="[40, 170]">
        <Label
          text="Enter this code on your server's web dashboard:"
          width="1120"
          height="35"
          font="font:SmallestSystemFont"
          color="0xFFFFFFFF"
          horizAlign="center"
          translation="[0, 55]" />
        <Label
          id="quickConnectCode"
          text=""
          width="1120"
          height="80"
          font="font:LargestSystemFont"
          color="0x00A4DCFF"
          horizAlign="center"
          translation="[0, 110]" />
        <Spinner scale="[0.4, 0.4]" translation="[535, 220]" />
        <Label
          id="quickConnectStatus"
          text="Waiting for authorization..."
          width="1120"
          height="35"
          font="font:TinySystemFont"
          color="0x9CA3AFFF"
          horizAlign="center"
          translation="[0, 290]" />
        <StandardButton
          id="quickConnectBack"
          text="Back"
          height="50"
          width="1120"
          translation="[0, 345]"
          background="0x2a2e40FF"
          color="0xFFFFFFFF"
          focusBackground="0x00A4DCFF"
          focusColor="0xFFFFFFFF"
          fontSize="24" />
      </Group>

    </Poster>

    <Timer id="quickConnectTimer" duration="3" repeat="true" />
  </children>
  <interface>
    <field id="user" type="string" onchange="onUserChange" value="" />
    <field id="alert" type="string" onchange="onAlertChange" value="" />
    <field id="quickConnectJson" type="assocarray" />
    <field id="quickConnectAuthenticated" type="boolean" alwaysNotify="true" />
    <field id="showQuickConnect" type="boolean" onchange="onShowQuickConnect" />
  </interface>
</component>