<?xml version="1.0" encoding="utf-8"?>
<component name="SetServerScreen" extends="JFScreen">
  <children>
    <Poster
      id="background"
      uri="pkg:/images/bg_login_gradient.png"
      width="1920"
      height="1080"
      translation="[0, 0]" />

    <Rectangle translation="[710, 70]" width="500" height="113" color="0x00000000">
      <Poster
        id="logo"
        uri="pkg:/images/logo.png"
        width="500"
        height="113" />
    </Rectangle>

    <Poster
      id="mainGroup"
      translation="[360, 215]"
      width="1200"
      height="420"
      uri="pkg:/images/surface.9.png">

      <Text
        id="discoveredLabel"
        text="Discovered Servers"
        font="font:SmallestBoldSystemFont"
        color="#FFFFFFFF"
        translation="[40, 40]" />

      <Rectangle
        id="serverPickerContainer"
        translation="[40, 85]"
        width="1120"
        height="220"
        color="0x00000000">
        <MarkupList
          id="serverPicker"
          translation="[0, 0]"
          drawFocusFeedback="false"
          itemComponentName="JFServer"
          focusFootprintBitmapUri=""
          itemSpacing="[0, 10]"
          itemSize="[1120, 100]"
          numRows="3"
          vertFocusAnimationStyle="floatingFocus" />
      </Rectangle>

      <StandardButton
        id="addServerButton"
        text="Add Server"
        width="1120"
        height="50"
        translation="[40, 320]"
        background="0x2a2e40FF"
        color="0xFFFFFFFF"
        focusBackground="0x00A4DCFF"
        focusColor="0xFFFFFFFF"
        fontSize="24" />

      <Rectangle
        id="serverUrlContainer"
        visible="false"
        translation="[40, 105]"
        width="1120"
        height="60"
        color="0x2a2e40FF">
        <TextEditBox
          id="serverUrlTextbox"
          hintText="Enter server address"
          width="1120"
          height="60"
          translation="[20, 2]" />
        <Poster
          id="serverUrlOutline"
          visible="false"
          uri="pkg:/images/hd_focus.9.png" />
      </Rectangle>

      <StandardButton
        id="connectButton"
        text="Connect"
        visible="false"
        width="550"
        height="50"
        translation="[610, 195]"
        background="0x2a2e40FF"
        color="0xFFFFFFFF"
        focusBackground="0x00A4DCFF"
        focusColor="0xFFFFFFFF"
        fontSize="24" />

      <StandardButton
        id="cancelButton"
        text="Cancel"
        visible="false"
        width="550"
        height="50"
        translation="[40, 195]"
        background="0x2a2e40FF"
        color="0xFFFFFFFF"
        focusBackground="0x00A4DCFF"
        focusColor="0xFFFFFFFF"
        fontSize="24" />

      <Text
        id="errorMessage"
        text=""
        font="font:TinySystemFont"
        color="#ff0000FF"
        width="1120"
        horizAlign="center"
        translation="[40, 255]" />
    </Poster>

    <Text
      id="versionLabel"
      font="font:TinyBoldSystemFont"
      text="Moonfin version x.x.x"
      color="#CCCCCC"
      translation="[844, 655]" />
  </children>

  <interface>
    <field id="forgetServer" type="string" />
    <field id="serverUrl" type="string" alias="serverUrlTextbox.text" />
    <field id="serverWidth" alias="serverUrlOutline.width,serverUrlContainer.width" value="1120" />
    <field id="serverHeight" alias="serverUrlOutline.height,serverUrlTextbox.height,serverUrlContainer.height" value="60" />
    <field id="errorMessage" type="string" alias="errorMessage.text" />
  </interface>
</component>