<?xml version="1.0" encoding="utf-8"?>
<component name="SetServerScreen" extends="JFScreen">
  <children>
    <Poster
      id="background"
      uri="pkg:/images/bg_login_gradient.png"
      width="1920"
      height="1080"
      translation="[0, 0]" />

    <Rectangle translation="[818, 70]" width="286" height="50" color="0x00000000">
      <Poster
        id="logo"
        uri="pkg:/images/logo.png"
        width="286"
        height="50" />
    </Rectangle>

    <Rectangle
      id="mainGroup"
      translation="[150, 200]"
      width="1620"
      height="500"
      color="#2b304473">

      <Text
        id="welcomeTitle"
        text="Welcome to Moonfin!"
        font="font:LargeBoldSystemFont"
        color="#FFFFFFFF"
        translation="[40, 40]" />

      <Text
        id="subtitle"
        text="Connect to your server to get started."
        font="font:SmallerSystemFont"
        color="#CCCCCC"
        width="1540"
        horizAlign="center"
        translation="[40, 100]" />

      <Rectangle
        id="serverUrlContainer"
        translation="[40, 150]"
        width="1540"
        height="60">
        <TextEditBox
          id="serverUrlTextbox"
          hintText="Enter server address"
          width="1520"
          height="60"
          translation="[20, 2]" />
        <Poster
          id="serverUrlOutline"
          visible="false"
          uri="pkg:/images/hd_focus.9.png" />
      </Rectangle>

      <Text
        id="discoveredLabel"
        text="Discovered servers"
        font="font:MediumSystemFont"
        color="#FFFFFFFF"
        translation="[40, 235]" />

      <Rectangle
        id="serverPickerContainer"
        translation="[40, 275]"
        width="1540"
        height="220"
        color="0x00000000"
        clippingRect="[0, 0, 1540, 220]">
        <MarkupList
          id="serverPicker"
          translation="[0, 0]"
          drawFocusFeedback="false"
          itemComponentName="JFServer"
          focusFootprintBitmapUri=""
          itemSpacing="[0, 10]"
          itemSize="[1540, 60]"
          numRows="2"
          vertFocusAnimationStyle="floatingFocus" />
      </Rectangle>

      <Text
        id="errorMessage"
        text=""
        font="font:MediumSystemFont"
        color="#ff0000FF"
        width="1540"
        horizAlign="center"
        translation="[40, 520]" />

      <StandardButton
        id="submit"
        text="Submit"
        width="250"
        height="60"
        translation="[685, 420]" />
    </Rectangle>
  </children>

  <interface>
    <field id="forgetServer" type="string" />
    <field id="serverUrl" type="string" alias="serverUrlTextbox.text" />
    <field id="serverWidth" alias="serverUrlOutline.width,serverUrlContainer.width" value="1540" />
    <field id="serverHeight" alias="serverUrlOutline.height,serverUrlTextbox.height,serverUrlContainer.height" value="60" />
    <field id="errorMessage" type="string" alias="errorMessage.text" />
  </interface>
</component>