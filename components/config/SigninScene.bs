import "pkg:/source/enums/KeyCode.bs"
import "pkg:/source/enums/String.bs"
import "pkg:/source/utils/misc.bs"

sub init()
    m.top.setFocus(true)
    m.top.optionsAvailable = false

    m.connectingTo = m.top.findNode("connectingTo")

    m.submit = m.top.findNode("submit")
    m.quickConnect = m.top.findNode("quickConnect")
    m.passwordTab = m.top.findNode("passwordTab")
    m.passwordTab.observeField("buttonSelected", "hideQuickConnect")
    m.back = m.top.findNode("back")
    m.back.observeField("buttonSelected", "onBackPressed")
    m.passwordTab.background = "0x00A4DCFF"
    m.quickConnect.background = "0x2a2e40FF"

    m.errorContainer = m.top.findNode("errorContainer")
    m.errorContainer.color = "#CC0000"

    m.config = m.top.findNode("configOptions")
    m.config.focusBitmapBlendColor = "0x00A4DCFF" ' Blue focus 

    username_field = CreateObject("roSGNode", "ConfigData")
    username_field.label = tr("Username")
    username_field.type = "string"
    username_field.value = string.EMPTY

    password_field = CreateObject("roSGNode", "ConfigData")
    password_field.label = tr("Password")
    password_field.type = "password"
    registryPassword = get_setting("password")
    if isValid(registryPassword)
        password_field.value = registryPassword
    end if

    saveCredentials = m.top.findNode("saveCredentials")
    saveCredentials.focusedColor = "0x00A4DCFF" ' Blue focus
    saveCredentials.font.size = 30
    saveCredentials.focusedFont.size = 30

    if not isStringEqual(get_setting("saveCredentials", "true"), "true")
        saveCredentials.checkedState = "[false]"
    end if

    items = [username_field, password_field]
    m.config.configItems = items

    saveCredentials.checkedIconUri = "pkg:/images/icons/checkboxChecked.png"
    saveCredentials.focusedCheckedIconUri = "pkg:/images/icons/checkboxChecked.png"

    saveCredentials.uncheckedIconUri = "pkg:/images/icons/checkboxUnchecked.png"
    saveCredentials.focusedUncheckedIconUri = "pkg:/images/icons/checkboxUnchecked.png"

    m.quickConnectGroup = m.top.findNode("quickConnectGroup")
    m.quickConnectCode = m.top.findNode("quickConnectCode")
    m.quickConnectStatus = m.top.findNode("quickConnectStatus")
    m.quickConnectBack = m.top.findNode("quickConnectBack")

    m.quickConnectTimer = m.top.findNode("quickConnectTimer")
    m.quickConnectTimer.observeField("fire", "quickConnectStatus")

    m.quickConnectGroup.visible = false
    m.quickConnectBack.observeField("buttonSelected", "onBackPressed")

    initServerName()
end sub

sub initServerName()
    serverName = m.global.session.server.name
    if not isValidAndNotEmpty(serverName)
        serverUrl = get_setting("server") ?? ""
        if serverUrl = ""
            m.connectingTo.text = tr("")
            return
        end if

        serverName = serverUrl.replace("https://", "").replace("http://", "")
        colonPos = serverName.instr(":")
        slashPos = serverName.instr("/")
        endPos = serverName.len()
        if colonPos >= 0 and colonPos < endPos then endPos = colonPos
        if slashPos >= 0 and slashPos < endPos then endPos = slashPos
        serverName = serverName.left(endPos)
    end if

    m.connectingTo.text = tr("Connecting to ") + serverName
end sub

sub onAlertChange()
    m.errorContainer.visible = isValidAndNotEmpty(m.top.alert)

    errorMessage = m.top.findNode("errorMessage")
    errorMessage.text = m.top.alert
end sub

sub onUserChange()
    username_field = m.config.content.getChild(0)

    if isStringEqual(m.top.user, string.EMPTY) and isValid(get_setting("username"))
        username_field.value = get_setting("username")
    else
        username_field.value = m.top.user
    end if

    ' Username has been provided, focus on password field
    if not isStringEqual(username_field.value, string.EMPTY)
        m.config.jumpToItem = 1
    end if
end sub

sub showQuickConnect()
    m.top.findNode("signInFormContainer").visible = false
    m.quickConnectGroup.visible = true
    m.quickConnectBack.setFocus(true)

    m.quickConnect.background = "0x00A4DCFF"
    m.passwordTab.background = "0x2a2e40FF"

    json = m.top.quickConnectJson
    if not isValid(json)
        m.top.alert = tr("Quick Connect not available.")
        hideQuickConnect()
        return
    end if

    m.quickConnectCode.text = json.Code

    m.quickConnectTimer.control = "start"
end sub

sub hideQuickConnect()
    if isValid(m.quickConnectTimer)
        m.quickConnectTimer.control = "stop"
    end if
    if isValid(m.checkTask)
        m.checkTask.control = "stop"
        m.checkTask.unobserveField("authenticated")
        m.checkTask = invalid
    end if

    m.top.showQuickConnect = false
    m.quickConnectGroup.visible = false
    m.top.findNode("signInFormContainer").visible = true

    m.passwordTab.background = "0x00A4DCFF"
    m.quickConnect.background = "0x2a2e40FF"
    
    m.submit.setFocus(true)
end sub

sub onQuickConnectAuthenticated()
    authenticated = m.checkTask.authenticated
    if authenticated > 0
        currentUser = AboutMe()
        session.user.Login(currentUser, m.top.findNode("saveCredentials").checkedState[0])
        session.user.LoadUserPreferences()
        LoadUserAbilities()
        
        m.top.quickConnectAuthenticated = true
    else if authenticated < 0
        m.quickConnectTimer.control = "start"
    end if
end sub

sub quickConnectStatus()
    m.quickConnectTimer.control = "stop"
    m.checkTask = CreateObject("roSGNode", "QuickConnect")
    m.checkTask.secret = m.top.quickConnectJson.secret
    m.checkTask.saveCredentials = m.top.findNode("saveCredentials").checkedState[0]
    m.checkTask.observeField("authenticated", "onQuickConnectAuthenticated")
    m.checkTask.control = "run"
end sub

sub onShowQuickConnect()
    showQuickConnect()
end sub

sub onBackPressed()
    m.top.backPressed = true
end sub

function onKeyEvent(key as string, press as boolean) as boolean
    ' Returns true if user navigates to a new focusable element
    if not press then return false

    if m.quickConnectGroup.visible
        if key = KeyCode.BACK
            m.top.backPressed = true
            return true
        end if

        if key = KeyCode.UP and m.quickConnectBack.hasFocus()
            m.quickConnectBack.focus = false
            m.quickConnect.setFocus(true)
            m.quickConnect.focus = true
            setLastFocus(m.quickConnect)
            return true
        end if

        if key = KeyCode.DOWN and (m.quickConnect.hasFocus() or m.passwordTab.hasFocus())
            if m.quickConnect.hasFocus() then m.quickConnect.focus = false
            if m.passwordTab.hasFocus() then m.passwordTab.focus = false
            m.quickConnectBack.setFocus(true)
            m.quickConnectBack.focus = true
            setLastFocus(m.quickConnectBack)
            return true
        end if
    end if

    list = m.top.findNode("configOptions")
    saveCredentials = m.top.findNode("saveCredentials")

    if key = KeyCode.BACK
        m.top.backPressed = true
        return false
    end if

    if key = KeyCode.DOWN and list.isInFocusChain()
        limit = list.content.getChildren(-1, 0).count() - 1
        if limit = list.itemFocused
            saveCredentials.setFocus(true)
            setLastFocus(saveCredentials)
            return true
        end if
        return false
    end if

    if key = KeyCode.DOWN and saveCredentials.isInFocusChain()
        m.submit.setFocus(true)
        m.submit.focus = true
        setLastFocus(m.submit)
        return true
    end if

    if key = KeyCode.UP and m.submit.hasFocus()
        m.submit.focus = false
        saveCredentials.setFocus(true)
        setLastFocus(saveCredentials)
        return true
    end if

    if key = KeyCode.UP and saveCredentials.isInFocusChain()
        list.setFocus(true)
        setLastFocus(list)
        return true
    end if

    if key = KeyCode.UP and list.isInFocusChain()
        m.quickConnect.setFocus(true)
        m.quickConnect.focus = true
        setLastFocus(m.quickConnect)
        return true
    end if

    if key = KeyCode.DOWN and m.quickConnect.hasFocus()
        m.quickConnect.focus = false
        list.setFocus(true)
        setLastFocus(list)
        return true
    end if

    if key = KeyCode.DOWN and m.passwordTab.hasFocus()
        m.passwordTab.focus = false
        list.setFocus(true)
        setLastFocus(list)
        return true
    end if

    if key = KeyCode.RIGHT and m.quickConnect.hasFocus()
        m.quickConnect.focus = false
        m.passwordTab.setFocus(true)
        m.passwordTab.focus = true
        setLastFocus(m.passwordTab)
        return true
    end if

    if key = KeyCode.LEFT and m.passwordTab.hasFocus()
        m.passwordTab.focus = false
        m.quickConnect.setFocus(true)
        m.quickConnect.focus = true
        setLastFocus(m.quickConnect)
        return true
    end if

    if key = KeyCode.LEFT and m.submit.hasFocus()
        m.submit.focus = false
        m.back.setFocus(true)
        m.back.focus = true
        setLastFocus(m.back)
        return true
    end if

    if key = KeyCode.RIGHT and m.back.hasFocus()
        m.back.focus = false
        m.submit.setFocus(true)
        m.submit.focus = true
        setLastFocus(m.submit)
        return true
    end if

    ' StandardButton's onKeyEvent handles OK press and sets buttonSelected
    ' No need to handle OK here anymore

    return false
end function
