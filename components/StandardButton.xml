<?xml version="1.0" encoding="utf-8"?>
<component name="StandardButton" extends="Group" focusable="true">
  <children>
    <Poster id="buttonBackground" uri="pkg:/images/hd_focus_filled.9.png" />
    <Text id="buttonText" font="font:SmallSystemFont" horizAlign="center" vertAlign="center" />
    <Poster id="focusFeedback" visible="false" uri="pkg:/images/hd_focus.9.png" />
  </children>
  <interface>
    <field id="background" type="color" value="" />
    <field id="focusBackground" type="color" value="" />
    <field id="color" type="color" value="" />
    <field id="focusColor" type="color" value="" />
    <field id="text" type="string" value="" />
    <field id="height" type="integer" value="" />
    <field id="width" type="integer" value="" />
    <field id="fontSize" type="integer" value="0" />
    <field id="selected" type="boolean" value="false" alwaysNotify="true" />
    <field id="focus" type="boolean" />
    <field id="escape" type="string" value="" />
    <field id="buttonSelected" type="boolean" value="false" alwaysNotify="true" />
  </interface>
</component>