<?xml version="1.0" encoding="utf-8"?>
<component name="SeerrPoster" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="itemContentChanged" />
        <field id="itemHasFocus" type="boolean" onChange="focusChanged" alwaysNotify="true" />
        <field id="drawFocusFeedback" type="boolean" value="true" />
    </interface>

    <children>
        <!-- Backdrop: 180x270 to match Home row MOVIE_POSTER size -->
        <Rectangle id="backdrop"
            width="180"
            height="270"
            translation="[0, 0]"
            color="#1E1E1E"
            opacity="1.0"
            visible="true" />

        <!-- Poster: 180x270 to match Home row MOVIE_POSTER size -->
        <Poster id="poster"
            width="180"
            height="270"
            translation="[0, 0]"
            loadDisplayMode="scaleToZoom"
            failedBitmapUri="pkg:/images/media_type_icons/movie.png"
            loadingBitmapUri="pkg:/images/media_type_icons/movie.png" />

        <!-- Gradient overlay at bottom for genre text readability (hidden by default) -->
        <Rectangle id="gradientOverlay"
            width="180"
            height="100"
            translation="[0, 170]"
            color="#000000"
            opacity="0.7"
            visible="false" />

        <!-- Title overlaid on poster for genres/networks/studios (hidden by default) -->
        <Label id="overlayTitle"
            width="172"
            height="80"
            translation="[4, 185]"
            font="font:SmallBoldSystemFont"
            color="#FFFFFF"
            horizAlign="center"
            vertAlign="center"
            wrap="true"
            maxLines="3"
            visible="false" />

        <!-- Title: ScrollingLabel directly below poster (for regular items) -->
        <ScrollingLabel id="title"
            height="64"
            translation="[8, 276]"
            font="font:SmallBoldSystemFont"
            color="#FFFFFF"
            horizAlign="center"
            vertAlign="center"
            maxWidth="172"
            repeatCount="0" />
    </children>
</component>