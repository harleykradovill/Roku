<?xml version="1.0" encoding="utf-8"?>
<component name="UserItem" extends="Group">
  <children>
    <LayoutGroup layoutDirection="vert" horizAlignment="center" translation="[10, 10]" itemSpacings="[12]">
      <Group id="avatarContainer">
        <Poster id="avatarRing"
          width="164"
          height="164"
          uri="pkg:/images/icons/circle64.png"
          loadDisplayMode="scaleToFit"
          blendColor="0x6B728099" />

        <Poster id="avatarBg"
          width="150"
          height="150"
          translation="[7, 7]"
          uri="pkg:/images/icons/circle64.png"
          loadDisplayMode="scaleToFit"
          blendColor="0x1F2937FF" />

        <MaskGroup maskUri="pkg:/images/icons/circle64.png" maskSize="[150, 150]" translation="[7, 7]">
          <Poster id="profileImage"
            width="150"
            height="150"
            loadDisplayMode="scaleToZoom" />
        </MaskGroup>
      </Group>

      <Label id="profileName"
        horizAlign="center"
        vertAlign="center"
        font="font:SmallBoldSystemFont"
        color="0xD1D5DBFF"
        height="30"
        width="180" />
    </LayoutGroup>
  </children>
  <interface>
    <field id="itemHasFocus" type="boolean" onChange="onFocusChanged" alwaysNotify="true" />
    <field id="itemContent" type="node" onChange="itemContentChanged" />
  </interface>
</component>