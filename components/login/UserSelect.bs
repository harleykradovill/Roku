import "pkg:/source/enums/AnimationControl.bs"
import "pkg:/source/enums/KeyCode.bs"
import "pkg:/source/enums/String.bs"
import "pkg:/source/utils/config.bs"
import "pkg:/source/utils/misc.bs"

sub init()
    m.top.optionsAvailable = false

    m.hiddenUsers = m.top.findNode("hiddenUsers")

    m.userRow = m.top.findNode("userRow")
    m.userRow.observeField("itemFocused", "onUserFocusChanged")

    m.hiddenUsers.focusBitmapBlendColor = "0x00A4DCFF"
    m.hiddenUsers.focusedColor = "0xFFFFFFFF"
    m.hiddenUsers.color = "0xFFFFFFCC"

    m.editButton = m.top.findNode("editButton")
    m.editButton.background = "0x2a2e40FF"
    m.editButton.color = "0xFFFFFFFF"
    m.editButton.focusBackground = "0x00A4DCFF"
    m.editButton.focusColor = "0xFFFFFFFF"
    m.editButton.observeField("buttonSelected", "onEditButtonSelected")

    m.manualLogin = m.top.findNode("manualLogin")
    m.manualLogin.background = "0x2a2e40FF"
    m.manualLogin.color = "0xFFFFFFFF"
    m.manualLogin.focusBackground = "0x00A4DCFF"
    m.manualLogin.focusColor = "0xFFFFFFFF"

    m.changeServer = m.top.findNode("changeServer")
    m.changeServer.background = "0x2a2e40FF"
    m.changeServer.color = "0xFFFFFFFF"
    m.changeServer.focusBackground = "0x00A4DCFF"
    m.changeServer.focusColor = "0xFFFFFFFF"
    m.changeServer.observeField("buttonSelected", "onChangeServerSelected")

    m.hiddenUserAnimation = m.top.findNode("hiddenUserAnimation")
    m.hiddenUserSlider = m.top.findNode("hiddenUserSlider")
    m.viewContentSlider = m.top.findNode("viewContentSlider")

    initServerName()
end sub

sub initServerName()
    serverName = m.global.session.server.name
    if not isValidAndNotEmpty(serverName)
        serverUrl = get_setting("server") ?? ""
        if serverUrl = "" then return

        serverName = serverUrl.replace("https://", "").replace("http://", "")
        colonPos = serverName.instr(":")
        slashPos = serverName.instr("/")
        endPos = serverName.len()
        if colonPos >= 0 and colonPos < endPos then endPos = colonPos
        if slashPos >= 0 and slashPos < endPos then endPos = slashPos
        serverName = serverName.left(endPos)
    end if
    m.top.findNode("serverName").text = serverName
end sub

sub onChangeServerSelected()
    if m.changeServer.buttonSelected
        m.top.changeServer = true
    end if
end sub

sub onEditButtonSelected()
    if not m.editButton.buttonSelected then return

    if isValidAndNotEmpty(m.top.hiddenUserList)
        m.viewContentSlider.reverse = false
        m.hiddenUserSlider.reverse = false
        m.hiddenUserAnimation.control = AnimationControl.START
        m.hiddenUsers.setFocus(true)
        m.editButton.focus = false
    end if
end sub

sub onHiddenUserListChanged()
    if not isValidAndNotEmpty(m.top.hiddenUserList)
        m.hiddenUsers.content = CreateObject("roSGNode", "ContentNode")
        if m.hiddenUsers.isInFocusChain()
            m.hiddenUserSlider.reverse = true
            m.viewContentSlider.reverse = true
            m.hiddenUserAnimation.control = AnimationControl.START

            m.editButton.focus = true
            m.editButton.setFocus(true)
        end if
        return
    end if

    hiddenUserList = CreateObject("roSGNode", "ContentNode")

    for each user in m.top.hiddenUserList
        if user.id = string.EMPTY then continue for

        row = CreateObject("roSGNode", "PublicUserData")
        row.title = user.Name
        row.id = user.id
        row.Name = user.Name
        row.isPublic = user.isPublic
        row.imageURL = user.imageURL

        hiddenUserList.appendChild(row)
    end for

    m.hiddenUsers.content = hiddenUserList
end sub

sub itemContentChanged()
    stopLoadingSpinner()
    m.userRow.itemContent = m.top.itemContent
    if m.top.itemContent.count() = 0
        m.userRow.setFocus(false)
        m.editButton.setFocus(true)
        m.editButton.focus = true
    end if
    redraw()
end sub

const ITEM_WIDTH = 180
const ITEM_SPACING = 30
const CLIP_WIDTH = 1120

sub redraw()
    userCount = m.top.itemContent.Count()
    if userCount = 0 then return

    rowWidth = (userCount * ITEM_WIDTH) + ((userCount - 1) * ITEM_SPACING)

    if rowWidth <= CLIP_WIDTH
        centerOffset = (CLIP_WIDTH - rowWidth) / 2
        m.userRow.translation = [centerOffset, 0]
    else
        scrollUserRow()
    end if
end sub

sub onUserFocusChanged()
    scrollUserRow()
end sub

sub scrollUserRow()
    userCount = m.top.itemContent.Count()
    if userCount = 0 then return

    rowWidth = (userCount * ITEM_WIDTH) + ((userCount - 1) * ITEM_SPACING)
    if rowWidth <= CLIP_WIDTH then return

    focusedIndex = m.userRow.itemFocused
    if focusedIndex < 0 then focusedIndex = 0

    focusedItemLeft = focusedIndex * (ITEM_WIDTH + ITEM_SPACING)
    focusedItemRight = focusedItemLeft + ITEM_WIDTH

    currentOffset = -m.userRow.translation[0]

    if focusedItemRight > currentOffset + CLIP_WIDTH
        currentOffset = focusedItemRight - CLIP_WIDTH
    else if focusedItemLeft < currentOffset
        currentOffset = focusedItemLeft
    end if

    maxOffset = rowWidth - CLIP_WIDTH
    if currentOffset < 0 then currentOffset = 0
    if currentOffset > maxOffset then currentOffset = maxOffset

    m.userRow.translation = [-currentOffset, 0]
end sub

sub OnScreenShown(_isReturning = false as boolean)
    scene = m.top.getScene()
    activeNav = getActiveNav(scene)
    if isValid(activeNav)
        activeNav.isVisible = false
    end if
end sub

function onKeyEvent(key as string, press as boolean) as boolean
    if not press then return false

    if key = KeyCode.RIGHT
        if m.hiddenUsers.hasFocus()
            m.viewContentSlider.reverse = true
            m.hiddenUserSlider.reverse = true
            m.hiddenUserAnimation.control = AnimationControl.START

            m.editButton.setFocus(true)
            m.editButton.focus = true
            return true
        end if

        return false
    end if

    if key = KeyCode.LEFT
        return false
    end if

    if key = KeyCode.OK
        if m.hiddenUsers.isInFocusChain()
            m.top.showUser = m.hiddenUsers.content.getChild(m.hiddenUsers.itemFocused)
            return true
        end if
        return false
    end if

    if key = KeyCode.OPTIONS
        userList = m.userRow.itemContent
        user = userList[m.userRow.itemFocused]

        if not isValid(user) then return false

        if user.isPublic
            m.top.hideUser = user
            return true
        end if

        m.top.forgetUser = user.id
        return true
    end if

    if key = KeyCode.BACK
        m.top.backPressed = true
        return true
    end if

    if key = KeyCode.UP
        if m.editButton.hasFocus()
            if m.top.itemContent.count() > 0
                m.userRow.setFocus(true)
                m.editButton.focus = false
                return true
            end if
            return false
        end if

        if m.manualLogin.hasFocus()
            m.editButton.setFocus(true)
            m.editButton.focus = true
            m.manualLogin.focus = false
            return true
        end if

        if m.changeServer.hasFocus()
            m.manualLogin.setFocus(true)
            m.manualLogin.focus = true
            m.changeServer.focus = false
            return true
        end if

        return false
    end if

    if key = KeyCode.DOWN
        if m.userRow.isInFocusChain()
            m.editButton.setFocus(true)
            m.editButton.focus = true
            return true
        end if

        if m.editButton.hasFocus()
            m.manualLogin.setFocus(true)
            m.manualLogin.focus = true
            m.editButton.focus = false
            return true
        end if

        if m.manualLogin.hasFocus()
            m.changeServer.setFocus(true)
            m.changeServer.focus = true
            m.manualLogin.focus = false
            return true
        end if

        return false
    end if

    return false
end function
